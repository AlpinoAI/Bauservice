# Shape der Umgebungsvariablen für die Bauservice-Email-Automation.
# Für lokale Dev-Arbeit kopieren nach .env.local (gitignored) und Werte setzen.
# Phase 1 nutzt Dummy-Endpoints und braucht weder DATABASE_URL noch MAILJET_*.

# --- Basic-Auth-Middleware-Stub ---
# Passwort für den Phase-1-Auth-Stub. Wird in Phase 2 durch Magic-Link ersetzt.
APP_PASSWORD=change-me

# --- Backend-API (Matthias' Service, Phase 2) ---
# Öffentliche Basis-URL des Backends — sicher, weil ohne API-Key kein Zugriff möglich.
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001
# API-Key für den Backend-Service — nur server-seitig verwenden, nie NEXT_PUBLIC_!
# Wird nach Login via /api/auth/session an den Browser ausgegeben.
BACKEND_API_KEY=

# --- Bauservice-DB (Read-only) ---
# Format: mysql://user:password@host:3306/bauservice
# Phase 2: dediziertes Read-only-Konto gegen die vorgeschlagenen v_frontend_*-Views
# (siehe docs/sql-views-ddl-vorschlag.md). Produktiv empfohlen via VPN oder
# SSH-Tunnel — Plain-HTTP-phpMyAdmin ist nur Interims-Lösung.
DATABASE_URL=

# --- Mailjet (nach MVP-Abnahme) ---
# https://dev.mailjet.com/email/reference/ — API Key + Secret Key aus dem Dashboard.
# Sender-Authentication (DKIM + SPF + DMARC) für bauservice.it muss vorher
# eingerichtet sein, sonst Inbox-Placement in Gmail/Outlook unzuverlässig.
MAILJET_API_KEY=
MAILJET_API_SECRET=

# --- Auth (Kickoff) ---
# Magic-Link via Resend/SMTP als Default. Alternative: Basic-Auth-Middleware-Secret
# für MVP-Abnahme, falls Magic-Link-Infra später kommt.
AUTH_BASIC_SECRET=
RESEND_API_KEY=
